---
interface Props {
  variant?: 'leaf' | 'curve'
  class?: string
}

const { variant = 'leaf', class: className = '' } = Astro.props
---

{
  variant === 'leaf' && (
    <svg
      class={`decor decor-leaf ${className}`}
      viewBox="0 0 200 200"
      aria-hidden="true"
      focusable="false"
    >
      <g fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <path d="M30 170 C 60 140, 90 100, 110 60" />
        <path d="M50 165 Q 70 150, 78 130" />
        <path d="M65 155 Q 80 140, 88 120" />
        <path d="M80 140 Q 92 128, 98 110" />
        <path d="M95 125 Q 102 115, 106 100" />
        <path d="M108 105 Q 112 95, 113 85" />
      </g>
      <g fill="currentColor" opacity="0.5">
        <ellipse cx="115" cy="55" rx="3" ry="3" />
        <ellipse cx="125" cy="40" rx="2" ry="2" />
        <ellipse cx="135" cy="48" rx="2.5" ry="2.5" />
      </g>
    </svg>
  )
}

{
  variant === 'curve' && (
    <svg
      class={`decor decor-curve ${className}`}
      viewBox="0 0 400 100"
      aria-hidden="true"
      focusable="false"
      preserveAspectRatio="none"
    >
      <path
        d="M0 60 Q 100 20, 200 50 T 400 40"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
      />
    </svg>
  )
}

<style>
  .decor {
    color: var(--accent-2);
    opacity: 0.45;
    pointer-events: none;
    user-select: none;
  }
  .decor-leaf {
    width: 100%;
    height: 100%;
  }
  .decor-curve {
    width: 100%;
    height: auto;
  }
</style>
