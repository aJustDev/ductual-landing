---
const features = [
  {
    title: 'Agenda',
    desc: 'Slots, recordatorios automaticos y sincronizacion con Google Calendar.',
    icon: 'calendar',
  },
  {
    title: 'Ficha clinica con RGPD',
    desc: 'Notas cifradas, exportable y control completo del paciente sobre sus datos.',
    icon: 'shield',
  },
  {
    title: 'Facturacion',
    desc: 'Verifactu/AEAT, IVA correcto y sin hojas de calculo paralelas.',
    icon: 'doc',
  },
] as const
---

<section class="features container" aria-labelledby="features-title">
  <h2 id="features-title" class="section-title">Lo que cubrimos</h2>
  <div class="grid">
    {
      features.map((f) => (
        <article class="card">
          <div class="icon" aria-hidden="true">
            {f.icon === 'calendar' && (
              <svg viewBox="0 0 32 32" fill="none">
                <rect
                  x="4"
                  y="6"
                  width="24"
                  height="22"
                  rx="3"
                  stroke="currentColor"
                  stroke-width="1.4"
                />
                <path
                  d="M4 12 H28"
                  stroke="currentColor"
                  stroke-width="1.4"
                />
                <path
                  d="M11 4 V8 M21 4 V8"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                />
                <circle cx="11" cy="18" r="1.4" fill="currentColor" />
                <circle cx="16" cy="18" r="1.4" fill="currentColor" />
                <circle cx="21" cy="18" r="1.4" fill="currentColor" />
                <circle cx="11" cy="23" r="1.4" fill="currentColor" />
                <circle cx="16" cy="23" r="1.4" fill="currentColor" />
              </svg>
            )}
            {f.icon === 'shield' && (
              <svg viewBox="0 0 32 32" fill="none">
                <path
                  d="M16 4 L26 8 V16 C26 22 21 27 16 28 C11 27 6 22 6 16 V8 Z"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
                <path
                  d="M11 16 L15 20 L21 12"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            )}
            {f.icon === 'doc' && (
              <svg viewBox="0 0 32 32" fill="none">
                <path
                  d="M8 4 H20 L26 10 V26 A2 2 0 0 1 24 28 H8 A2 2 0 0 1 6 26 V6 A2 2 0 0 1 8 4 Z"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
                <path
                  d="M20 4 V10 H26"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
                <path
                  d="M11 16 H21 M11 20 H21 M11 24 H17"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linecap="round"
                />
              </svg>
            )}
          </div>
          <h3 class="card-title">{f.title}</h3>
          <p class="card-desc">{f.desc}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .features {
    padding-block: var(--section-py);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--text);
    margin-bottom: 2.5rem;
    text-align: center;
    letter-spacing: -0.005em;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 720px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--border-strong);
  }

  .icon {
    width: 44px;
    height: 44px;
    color: var(--accent);
    margin-bottom: 1.25rem;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    display: grid;
    place-items: center;
    padding: 9px;
  }
  .icon svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.4rem;
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }
</style>
