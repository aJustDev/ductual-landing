---
---

<section id="waitlist" class="waitlist" aria-labelledby="waitlist-title">
  <div class="container card">
    <h2 id="waitlist-title" class="title">Apuntate a la lista de espera</h2>
    <p class="lede">
      Te avisamos por email cuando este disponible. Sin spam, solo lo importante.
    </p>

    <form id="subscribe-form" novalidate>
      <div class="field">
        <label for="email" class="label">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="tu@email.com"
          required
          autocomplete="email"
          aria-describedby="email-error"
        />
        <span class="field-error" id="email-error" aria-live="polite"></span>
      </div>

      <div class="consent">
        <label class="consent-label">
          <input type="checkbox" id="consent" name="consent" required />
          <span>
            He leido y acepto la <a href="/privacidad">politica de privacidad</a>.
          </span>
        </label>
        <span class="field-error" id="consent-error" aria-live="polite"></span>
      </div>

      <button type="submit" id="submit-btn">
        <span id="btn-text">Apuntarme</span>
      </button>

      <p class="microcopy">Sin spam. Te avisaremos cuando lancemos.</p>

      <div
        id="form-success"
        class="hidden success-msg"
        role="status"
        aria-live="polite"
      >
        <p>Apuntado. Te avisamos cuando lancemos.</p>
      </div>

      <div
        id="form-error"
        class="hidden error-banner"
        role="alert"
        aria-live="polite"
      >
        <p id="error-text">Algo salio mal. Intentalo de nuevo.</p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const btnText = document.getElementById('btn-text') as HTMLSpanElement
  const formSuccess = document.getElementById('form-success') as HTMLDivElement
  const formError = document.getElementById('form-error') as HTMLDivElement
  const errorText = document.getElementById('error-text') as HTMLParagraphElement
  const emailInput = document.getElementById('email') as HTMLInputElement
  const emailError = document.getElementById('email-error') as HTMLSpanElement
  const consentInput = document.getElementById('consent') as HTMLInputElement
  const consentError = document.getElementById('consent-error') as HTMLSpanElement

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    emailError.textContent = ''
    consentError.textContent = ''
    formError.classList.add('hidden')

    const email = emailInput.value.trim()
    const consent = consentInput.checked

    if (!EMAIL_RE.test(email)) {
      emailError.textContent = 'Introduce un email valido.'
      emailInput.focus()
      return
    }
    if (!consent) {
      consentError.textContent = 'Debes aceptar la politica de privacidad.'
      consentInput.focus()
      return
    }

    submitBtn.disabled = true
    btnText.textContent = 'Enviando...'

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, consent: true }),
      })

      if (res.ok) {
        form.classList.add('hidden')
        formSuccess.classList.remove('hidden')
      } else {
        const data = await res.json().catch(() => ({}))
        errorText.textContent =
          (data as { error?: string }).error ?? 'Algo salio mal. Intentalo de nuevo.'
        formError.classList.remove('hidden')
        submitBtn.disabled = false
        btnText.textContent = 'Apuntarme'
      }
    } catch {
      errorText.textContent = 'Error de conexion. Intentalo de nuevo.'
      formError.classList.remove('hidden')
      submitBtn.disabled = false
      btnText.textContent = 'Apuntarme'
    }
  })
</script>

<style>
  .waitlist {
    padding-block: var(--section-py);
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 540px;
    box-shadow: var(--shadow);
  }

  .title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.7rem, 3vw, 2.1rem);
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }

  .lede {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0 0 1.75rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text);
  }

  input[type='email'] {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-size: 1rem;
    font-family: var(--font-body);
    outline: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }
  input[type='email']:hover {
    border-color: var(--border-strong);
  }
  input[type='email']:focus {
    background: var(--surface);
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91, 122, 90, 0.18);
  }
  input[type='email']::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .consent {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .consent-label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1.5;
  }
  .consent input[type='checkbox'] {
    margin-top: 0.18rem;
    flex-shrink: 0;
    accent-color: var(--accent);
    width: 1rem;
    height: 1rem;
    cursor: pointer;
  }

  .field-error {
    font-size: 0.82rem;
    color: var(--error);
    min-height: 1rem;
  }

  button[type='submit'] {
    width: 100%;
    padding: 0.95rem 1rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    font-size: 1rem;
    font-weight: 500;
    font-family: var(--font-body);
    cursor: pointer;
    transition:
      background 180ms ease,
      transform 180ms ease;
    margin-top: 0.25rem;
  }
  button[type='submit']:hover:not(:disabled) {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
  button[type='submit']:active:not(:disabled) {
    transform: translateY(0);
  }
  button[type='submit']:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .microcopy {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }

  .success-msg {
    padding: 1rem 1.1rem;
    background: var(--accent-soft);
    border: 1px solid var(--accent-2);
    border-radius: var(--radius);
    color: var(--accent-hover);
    font-size: 0.92rem;
    text-align: center;
  }
  .success-msg p {
    margin: 0;
  }

  .error-banner {
    padding: 1rem 1.1rem;
    background: var(--error-bg);
    border: 1px solid var(--error);
    border-radius: var(--radius);
    color: var(--error);
    font-size: 0.92rem;
    text-align: center;
  }
  .error-banner p {
    margin: 0;
  }
</style>
