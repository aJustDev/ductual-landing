---
import Base from '../../layouts/Base.astro'
import { getDict } from '../../i18n'

const locale = 'ca'
const t = getDict(locale)
---

<Base
  title={t.meta.privacyTitle}
  description={t.meta.privacyDescription}
  locale={locale}
  pathEs="/privacidad"
  pathCa="/privacitat"
>
  <main class="container">
    <article>
      <a href="/" class="back">{t.privacy.back}</a>
      <h1>{t.privacy.h1}</h1>

      <div class="notice">{t.privacy.notice}</div>

      <h2>{t.privacy.contactBefore}</h2>
      {/* TODO: cuando este Email Routing en ductual.es, sustituir por privacidad@ductual.es */}
      <p>
        {t.privacy.contactName}<br />
        {t.privacy.contactEmailLabel}: <a href="mailto:ajustinodev@proton.me"
          >ajustinodev@proton.me</a
        >
      </p>

      {
        t.privacy.sections.map((s) => (
          <>
            <h2>{s.h}</h2>
            <p>{s.body}</p>
          </>
        ))
      }
    </article>
  </main>
</Base>

<style>
  main {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  article {
    max-width: 640px;
    margin-inline: auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    box-shadow: var(--shadow-sm);
  }

  .back {
    display: inline-block;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .back:hover {
    color: var(--accent);
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.9rem, 4vw, 2.4rem);
    margin-bottom: 1.5rem;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  .notice {
    padding: 1rem 1.1rem;
    background: var(--accent-soft);
    border: 1px solid var(--accent-2);
    border-radius: var(--radius);
    color: var(--accent-hover);
    font-size: 0.88rem;
    margin-bottom: 2rem;
    line-height: 1.55;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.3rem;
    margin: 2rem 0 0.5rem;
    color: var(--text);
    letter-spacing: -0.005em;
  }

  p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  p + p {
    margin-top: 0.75rem;
  }
</style>
